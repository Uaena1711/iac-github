# Per-stack identity for the dev workspace. PLACEHOLDERS — replace locally; do NOT commit
# real ARNs / bucket names / account ids. detect-changes reads AWS_ROLE_ARN + AWS_REGION
# into the job matrix; run.sh sources the rest for the S3 backend.
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/REPLACE_ME
AWS_REGION=us-east-1
AWS_STATE_BUCKET=REPLACE_ME
AWS_STATE_KMS_KEY=REPLACE_ME
